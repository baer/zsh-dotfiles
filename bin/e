#!/bin/sh
#
# Quick shortcut to the GUI/project editor.
#
# This means that as I travel back and forth between editors, hey, I don't have
# to re-learn any arcane commands. Neat.
#
# USAGE:
#
#   $ e
#   # => opens the current directory in your GUI/project editor
#
#   $ e .
#   $ e /usr/local
#   # => opens the specified directory in your GUI/project editor
exec "${E_EDITOR:-code}" "${1:-.}"
