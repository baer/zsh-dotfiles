#!/usr/bin/env bash
# git-ignore — manage gitignore patterns at three scopes. Run 'git ignore -h'.

set -euo pipefail

# -- helpers ---------------------------------------------------------

die()  { printf 'git-ignore: %s\n' "$1" >&2; exit "${2:-1}"; }
warn() { printf 'git-ignore: %s\n' "$1" >&2; }

# -- color detection ------------------------------------------------

# shellcheck disable=SC2034
if [ -n "${NO_COLOR:-}" ] || [ ! -t 1 ]; then
  is_tty=false
else
  is_tty=true
fi

# -- usage -----------------------------------------------------------

usage() {
  cat <<'EOF'
Usage: git ignore [-q|-v] <subcommand> [<scope>] [<args>...]

Manages gitignore patterns at three scopes: --global (your user-wide
ignore), --local (the repo's tracked .gitignore), --private (the
per-clone .git/info/exclude).

Subcommands:
  list              List patterns. Default scope: --all.
  add               Add patterns. Default scope: --local.
  rm                Remove patterns. Default scope: --local.
  edit              Open the scope's file in $GIT_EDITOR.
  path              Print the absolute path to the scope's file.

Scope flags (mutually exclusive):
  -l, --local       <repo>/.gitignore               (default for add, rm, edit, path)
  -g, --global      core.excludesFile, falling back to ~/.gitignore,
                    then $XDG_CONFIG_HOME/git/ignore
  -p, --private     <repo>/.git/info/exclude        (alias: --info)
  --all             list-only — every scope, in order: global, local, private

Global options:
  -q, --quiet       Suppress success summaries (errors still print).
  -v, --verbose     Print per-pattern action lines on stderr.
  -h, --help        Show this message.

Stdin:
  add and rm read patterns from stdin when '-' is given as the only
  positional argument. Lines starting with '#' and blank lines are
  skipped, so an existing .gitignore can be piped in directly.

Output:
  Stdout is reserved for content (list output, path output). All
  status, summaries, warnings, and errors go to stderr. list output
  is TTY-aware: scope headers when interactive, tab-separated when
  piped.

Exit codes:
  0  success
  1  usage error (unknown flag, missing arg, conflicting scopes,
     pattern containing literal newline)
  2  environment error (not in a repo when one is required)
  3  I/O error (can't read or write the target file)

Examples:
  git ignore                            # list all scopes (TTY-aware)
  git ignore add node_modules .env      # add to local
  git ignore add -g .DS_Store           # add to global
  git ignore add -p '*.swp'             # add to per-clone exclude
  git ignore rm .env                    # remove from local
  curl -s https://gitignore.io/api/macos | git ignore add -g -
  git ignore list -l > new.gitignore    # raw single-scope dump
  code "$(git ignore path -g)"          # open the global file
  git ignore edit -l                    # open repo's .gitignore
EOF
  exit 0
}

# -- parse global flags then dispatch ---------------------------------

quiet=false
verbose=false

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)    usage ;;
    -q|--quiet)   quiet=true; shift ;;
    -v|--verbose) verbose=true; shift ;;
    *)            break ;;
  esac
done

# Bare invocation = list --all
if [ $# -eq 0 ]; then
  set -- list --all
fi

subcommand="$1"; shift

# -- scope and path resolution ---------------------------------------

# Sets globals: scope, remaining_args (array)
parse_scope() {
  local scope_seen=""
  scope=""
  remaining_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -l|--local)
        [ -z "$scope_seen" ] || die "conflicting scope flags: $scope_seen and $1"
        scope="local"; scope_seen="$1"; shift ;;
      -g|--global)
        [ -z "$scope_seen" ] || die "conflicting scope flags: $scope_seen and $1"
        scope="global"; scope_seen="$1"; shift ;;
      -p|--private|--info)
        [ -z "$scope_seen" ] || die "conflicting scope flags: $scope_seen and $1"
        scope="private"; scope_seen="$1"; shift ;;
      --all)
        [ -z "$scope_seen" ] || die "conflicting scope flags: $scope_seen and $1"
        scope="all"; scope_seen="$1"; shift ;;
      --)
        shift
        while [ $# -gt 0 ]; do remaining_args+=("$1"); shift; done
        break ;;
      *)
        remaining_args+=("$1"); shift ;;
    esac
  done
}

need_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "not in a git repo" 2
}

resolve_path() {
  local s="$1" p
  case "$s" in
    local)
      need_repo
      printf '%s/.gitignore\n' "$(git rev-parse --show-toplevel)"
      ;;
    global)
      if p=$(git config --global --get core.excludesFile 2>/dev/null) && [ -n "$p" ]; then
        printf '%s\n' "${p/#~/$HOME}"
      elif [ -f "$HOME/.gitignore" ]; then
        printf '%s\n' "$HOME/.gitignore"
      else
        printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/git/ignore"
      fi
      ;;
    private)
      need_repo
      printf '%s\n' "$(git rev-parse --show-toplevel)/.git/info/exclude"
      ;;
    *) die "internal error: unknown scope '$s'" ;;
  esac
}

# -- io primitives ---------------------------------------------------

file_contains() {
  local file="$1" pattern="$2"
  [ -f "$file" ] || return 1
  grep -Fxq -- "$pattern" "$file"
}

ensure_trailing_newline() {
  local file="$1"
  [ -s "$file" ] || return 0
  # Append a sentinel byte to both sides so command substitution
  # does not strip the trailing newline we are trying to detect.
  [ "$(tail -c 1 "$file"; printf x)" = "$(printf '\nx')" ] && return 0
  printf '\n' >> "$file"
}

# shellcheck disable=SC2088  # ~/… in printf format is intentional display, not path expansion
relative_path() {
  local p="$1"
  case "$p" in
    "$PWD"/*) printf '%s\n' "${p#"$PWD"/}" ;;
    "$HOME"/*) printf '~/%s\n' "${p#"$HOME"/}" ;;
    *) printf '%s\n' "$p" ;;
  esac
}

# -- subcommands -----------------------------------------------------

cmd_path() {
  parse_scope "$@"
  set -- "${remaining_args[@]}"
  [ $# -eq 0 ] || die "path takes no positional arguments"
  [ "$scope" = "all" ] && die "path does not support --all"
  [ -z "$scope" ] && scope="local"
  resolve_path "$scope"
}

cmd_add() {
  parse_scope "$@"
  set -- "${remaining_args[@]}"
  [ "$scope" = "all" ] && die "add does not support --all"
  [ -z "$scope" ] && scope="local"

  [ $# -gt 0 ] || die "add requires patterns or '-' to read from stdin"

  local file
  file=$(resolve_path "$scope")

  local patterns=()
  if [ $# -eq 1 ] && [ "$1" = "-" ]; then
    local line
    while IFS= read -r line || [ -n "$line" ]; do
      # Trim leading/trailing whitespace
      line="${line#"${line%%[![:space:]]*}"}"
      line="${line%"${line##*[![:space:]]}"}"
      case "$line" in
        ''|'#'*) continue ;;
      esac
      patterns+=("$line")
    done
  else
    patterns=("$@")
  fi

  [ ${#patterns[@]} -eq 0 ] && return 0

  mkdir -p "$(dirname "$file")"
  [ -e "$file" ] || : > "$file"
  ensure_trailing_newline "$file"

  local added=0 skipped=0 p
  for p in "${patterns[@]}"; do
    if file_contains "$file" "$p"; then
      skipped=$((skipped + 1))
      $verbose && warn "skipping '$p' (already present)"
    else
      printf '%s\n' "$p" >> "$file"
      added=$((added + 1))
      $verbose && warn "adding '$p'"
    fi
  done

  # TODO(Task 8): cd to repo toplevel for local/private scopes so
  # relative_path renders ".gitignore" from any subdir; currently
  # the summary shows an absolute or ~-prefixed path when run from
  # a subdir. Same fix needed in cmd_rm.
  if ! $quiet; then
    local rel msg pat_word
    rel=$(relative_path "$file")
    pat_word="patterns"; [ "$added" -eq 1 ] && pat_word="pattern"
    msg="added $added $pat_word to $rel"
    [ "$skipped" -gt 0 ] && msg="$msg ($skipped already present)"
    warn "$msg"
  fi
}

case "$subcommand" in
  add)        cmd_add "$@" ;;
  path)       cmd_path "$@" ;;
  *)          die "unknown subcommand: $subcommand (see git ignore -h)" ;;
esac
