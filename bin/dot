#!/usr/bin/env bash
#
# dot — ongoing dotfiles maintenance
#
# Updates Homebrew packages, runs install scripts, and keeps things current.
# Run periodically to stay on the latest and greatest.

set -euo pipefail

parentDirectory="$(cd "$(dirname "$0")" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"
LOGFILE="$dotfilesDirectory/.dot.log"

# shellcheck source=../script/lib/output.sh
source "$dotfilesDirectory/script/lib/output.sh"

displayUsageAndExit() {
  cat <<EOF
dot — dotfiles maintenance

Usage: dot [options]

Options:
  -e, --edit    Open dotfiles directory for editing
  -h, --help    Show this help message and exit
EOF
  exit
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    "-h"|"--help")
      displayUsageAndExit
      ;;
    "-e"|"--edit")
      exec "$EDITOR" "$dotfilesDirectory"
      exit
      ;;
    *)
      log_error "Invalid option: $1"
      displayUsageAndExit
      ;;
  esac
  shift
done

# ---------------------------------------------------------------------------
# Traps
# ---------------------------------------------------------------------------

_on_exit() {
  _spinner_cleanup
}
trap '_on_exit' EXIT

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

: > "$LOGFILE"

printf "\n  ${_BOLD}dot${_RST} ${_DIM}update${_RST}\n\n"

export ZSH="$dotfilesDirectory"

# Install homebrew (if missing)
$ZSH/homebrew/install.sh >> "$LOGFILE" 2>&1

# Update homebrew
run_with_spinner "brew update" "$LOGFILE" \
  brew update

# Upgrade homebrew packages
spinner_start "brew upgrade"
if brew upgrade >> "$LOGFILE" 2>&1; then
  spinner_stop ok "brew upgrade"
else
  spinner_stop warn "brew upgrade (some packages skipped)"
fi

# Remind work machine users to configure cask skip list
if [[ -f "$HOME/.gusto/init.sh" ]] && [[ -z "${HOMEBREW_BUNDLE_CASK_SKIP:-}" ]]; then
  log_warn "Tip: Run 'script/brew-skip-detect' to skip company-managed casks."
fi

# Install Brewfile packages
run_with_streaming_spinner "brew bundle" "$LOGFILE" \
  brew bundle --file="$dotfilesDirectory/Brewfile" --no-lock

# Run topic install scripts
_install_count=0
while IFS= read -r -d '' installer; do
  [[ "$installer" == *"homebrew/install.sh" ]] && continue
  sh -c "$installer" >> "$LOGFILE" 2>&1
  _install_count=$((_install_count + 1))
done < <(find "$dotfilesDirectory" -name install.sh -not -path '*.git*' -print0)

if [[ $_install_count -gt 0 ]]; then
  log_success "$_install_count install scripts run"
fi

printf "\n  ${_GREEN}${_BOLD}✓${_RST} ${_DIM}Up to date${_RST}\n\n"
