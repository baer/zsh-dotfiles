#!/bin/sh
# git-up — pull default branch, rebase, stash/restore. Run 'git up -h'.

set -e

# -- helpers ---------------------------------------------------------

die()  { _exit_handled=true; printf 'git-up: %s\n' "$1" >&2; exit 1; }
warn() { printf 'git-up: %s\n' "$1" >&2; }

# -- color detection ------------------------------------------------

if [ -n "$NO_COLOR" ] || [ ! -t 1 ]; then
  color_flag="--no-color"
else
  color_flag="--color"
fi

# -- cleanup trap ----------------------------------------------------

_exit_handled=false

_trap_exit() {
  rc=$?
  [ "$rc" -eq 0 ] && return
  $_exit_handled && return

  set +e  # don't exit the trap on errors during cleanup

  warn "failed unexpectedly (exit $rc)"

  # Try to return to the original branch
  _restored_branch=false
  if [ -n "${current_branch:-}" ] && [ -n "${default_branch:-}" ] \
     && [ "$current_branch" != "$default_branch" ]; then
    _on_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
    if [ "$_on_branch" = "$default_branch" ]; then
      if git checkout "$current_branch" 2>/dev/null; then
        warn "returned to $current_branch"
        _restored_branch=true
      else
        warn "could not return to $current_branch — you are on $default_branch"
      fi
    else
      _restored_branch=true
    fi
  else
    _restored_branch=true
  fi

  # Restore stash only if we're back on the right branch
  if [ "${did_stash:-false}" = true ]; then
    if $_restored_branch; then
      if git stash pop; then
        warn "stash restored"
      else
        warn "stash pop failed — run 'git stash pop' manually"
      fi
    else
      warn "stash preserved — run 'git stash pop' after returning to $current_branch"
    fi
  fi
}

trap _trap_exit EXIT

usage() {
  cat <<'EOF'
Usage: git up [--rebase] [--interactive] [--before CMD] [--after CMD] [BRANCH]

Updates the default branch (main/master) from origin, then
returns to the branch you were on.  Dirty working trees are
auto-stashed and restored afterward.

Options:
  --rebase, -r          Rebase the current branch onto the default branch.
  --interactive, -i     Use interactive rebase (requires --rebase).
  -ri                   Same as --rebase --interactive.
  --before, -b CMD      Run CMD on the default branch after pulling.
                        Skipped if no new commits were pulled.
  --after, -a CMD       Run CMD on the current branch after the update.
                        Skipped if no meaningful changes occurred.
  -h                    Show this message.

Arguments:
  BRANCH                Target branch to rebase onto the updated default
                        branch. Implies --rebase. You will end up on BRANCH
                        after the operation completes.

Hook commands are passed to eval — use only with trusted input.
--before fires when new commits are pulled.
--after fires when new commits are pulled or rebase moved commits.

Changelog of pulled commits is printed after the update.

Examples:
  git up --rebase
  git up --rebase --interactive
  git up --before "make build" --after "yarn install"
  git up -r -b "make" -a "yarn"
  git up feature-branch
  git up feature-branch --interactive
  git up feature-branch -b "make" -a "yarn"
EOF
  exit 0
}

# Detect the default branch: remote HEAD first, then local fallback.
detect_default_branch() {
  # 1. Ask the remote
  ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) && {
    echo "${ref#refs/remotes/origin/}"
    return
  }
  # 2. Local fallback
  git show-ref --verify --quiet refs/heads/main   2>/dev/null && { echo main;   return; }
  git show-ref --verify --quiet refs/heads/master  2>/dev/null && { echo master; return; }
  return 1
}

# True if a rebase, merge, or cherry-pick is in progress.
has_inflight_operation() {
  git_dir=$(git rev-parse --git-dir)
  [ -d "$git_dir/rebase-merge" ]  || \
  [ -d "$git_dir/rebase-apply" ]  || \
  [ -f "$git_dir/MERGE_HEAD" ]    || \
  [ -f "$git_dir/CHERRY_PICK_HEAD" ]
}

# -- parse flags -----------------------------------------------------

rebase=false
rebase_interactive=false
before_cmd=""
after_cmd=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h)                   usage ;;
    -ri)                  rebase=true; rebase_interactive=true; shift ;;
    -r|--rebase)          rebase=true; shift ;;
    -i|--interactive)     rebase_interactive=true; shift ;;
    --before|-b)          [ -n "${2:-}" ] || die "$1 requires a command argument"
                          before_cmd="$2"; shift 2 ;;
    --after|-a)           [ -n "${2:-}" ] || die "$1 requires a command argument"
                          after_cmd="$2"; shift 2 ;;
    *)                    die "unknown option: $1 (see git up -h)" ;;
  esac
done

# -- preflight -------------------------------------------------------

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null) \
  || die "not on a branch (detached HEAD)"

has_inflight_operation \
  && die "resolve the in-progress rebase/merge/cherry-pick first"

default_branch=$(detect_default_branch) \
  || die "could not determine default branch"

printf 'git-up: updating %s from origin...\n' "$default_branch"

# -- stash (if needed) -----------------------------------------------

did_stash=false
if git status --porcelain | grep -qv '^??'; then
  git stash push -m "git-up: auto-stash from $current_branch" \
    || die "could not stash changes — resolve working tree first"
  did_stash=true
fi

# -- update default branch -------------------------------------------

if [ "$current_branch" = "$default_branch" ]; then
  old_head=$(git rev-parse HEAD)
  git pull --ff-only --prune
  new_head=$(git rev-parse HEAD)
else
  git checkout "$default_branch"
  old_head=$(git rev-parse HEAD)
  git pull --ff-only --prune
  new_head=$(git rev-parse HEAD)
fi

if [ "$old_head" != "$new_head" ]; then pulled_new=true; else pulled_new=false; fi

new_count=0
if $pulled_new; then
  new_count=$(git rev-list --count "$old_head".."$new_head")
fi

# -- before hook -----------------------------------------------------

if [ -n "$before_cmd" ]; then
  if $pulled_new; then
    echo "Running --before: $before_cmd"
    eval "$before_cmd" || warn "--before command failed"
  else
    warn "--before skipped (no new commits)"
  fi
fi

# -- changelog -------------------------------------------------------

if $pulled_new; then
  echo "Log:"
  # shellcheck disable=SC2086
  git log $color_flag --pretty=oneline --abbrev-commit "$old_head".."$new_head" \
    | sed 's/^/  /'
fi

# -- return to branch ------------------------------------------------

if [ "$current_branch" != "$default_branch" ]; then
  git checkout "$current_branch" || {
    warn "could not return to '$current_branch' — staying on $default_branch"
    if $did_stash; then
      warn "your stash is preserved — run 'git stash pop' when ready"
    fi
    _exit_handled=true; exit 1
  }
fi

# -- rebase (if --rebase) --------------------------------------------

did_rebase_change=false
if $rebase && [ "$current_branch" != "$default_branch" ]; then
  old_rebase_head=$(git rev-parse HEAD)
  if $rebase_interactive; then
    git rebase -i "$default_branch" || true
  else
    git rebase "$default_branch" || true
  fi

  if has_inflight_operation; then
    if $did_stash; then
      warn "rebase paused — run 'git stash pop' after completing the rebase"
    fi
    _exit_handled=true; exit 1
  fi
  if [ "$old_rebase_head" != "$(git rev-parse HEAD)" ]; then
    did_rebase_change=true
  fi
fi

# -- compute changed --------------------------------------------------

changed=false
$pulled_new && changed=true
$did_rebase_change && changed=true

# -- after hook ------------------------------------------------------

if [ -n "$after_cmd" ]; then
  if $changed; then
    echo "Running --after: $after_cmd"
    eval "$after_cmd" || warn "--after command failed"
  else
    warn "--after skipped (no changes)"
  fi
fi

# -- restore stash ----------------------------------------------------

was_stashed=$did_stash
stash_clean=false
if $was_stashed; then
  if git stash pop; then
    stash_clean=true
  else
    # Auto-resolve lockfile conflicts (keep the pulled version)
    _conflicted=$(git diff --name-only --diff-filter=U 2>/dev/null)
    if [ -z "$_conflicted" ]; then
      warn "stash pop failed — run 'git stash pop' manually"
    else
      _remaining=false
      for _f in $_conflicted; do
        case "${_f##*/}" in
          yarn.lock|package-lock.json|pnpm-lock.yaml|Gemfile.lock|Cargo.lock|poetry.lock|composer.lock|go.sum)
            if git checkout --ours -- "$_f" && git add -- "$_f"; then
              warn "auto-resolved $_f (kept pulled version — re-run your package manager)"
            else
              _remaining=true
            fi
            ;;
          *) _remaining=true ;;
        esac
      done

      if $_remaining; then
        warn "stash applied with conflicts — resolve manually"
      else
        git stash drop 2>/dev/null
        stash_clean=true
      fi
    fi
  fi
  did_stash=false  # consumed — prevent trap from re-popping
fi

# -- summary ---------------------------------------------------------

if $pulled_new; then
  summary="$default_branch updated ($new_count new)"
else
  summary="$default_branch already up to date"
fi
$did_rebase_change && summary="$summary, rebased $current_branch onto $default_branch"
if $was_stashed; then
  if $stash_clean; then
    summary="$summary, stash restored"
  else
    summary="$summary, stash conflicts (resolve manually)"
  fi
fi
printf 'git-up: %s\n' "$summary"
