#!/usr/bin/env bash
#
# bootstrap — first-time dotfiles setup
#
# Links dotfiles to $HOME, configures git, and installs dependencies.
# Safe to re-run: skips anything already in place.

set -euo pipefail

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
LOGFILE="$DOTFILES_ROOT/.bootstrap.log"

# shellcheck source=lib/output.sh
source "$DOTFILES_ROOT/script/lib/output.sh"

# ---------------------------------------------------------------------------
# Flags
# ---------------------------------------------------------------------------

DRY_RUN=false
SKIP_DEPS=false
SKIP_GIT=false
VERBOSE=false

usage() {
  cat <<EOF
Usage: script/bootstrap [options]

Sets up this machine from scratch — symlinks dotfiles, configures git,
and installs Homebrew packages.

Options:
  --help        Show this message
  --dry-run     Preview what would happen without changing anything
  --skip-git    Skip git config setup
  --skip-deps   Skip Homebrew and dependency installation
  --verbose     Show full command output instead of spinners
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)      usage ;;
    --dry-run)   DRY_RUN=true ;;
    --skip-deps) SKIP_DEPS=true ;;
    --skip-git)  SKIP_GIT=true ;;
    --verbose)   VERBOSE=true ;;
    *)
      log_error "Unknown option: $1"
      usage
      ;;
  esac
  shift
done

# ---------------------------------------------------------------------------
# Environment detection
# ---------------------------------------------------------------------------

IS_MACOS=false
[[ "$(uname -s)" == "Darwin" ]] && IS_MACOS=true

# Check if dotfiles are already linked (user's shell has reload! available)
_HAD_DOTFILES=false
[[ -L "$HOME/.zshrc" ]] && _HAD_DOTFILES=true

# ---------------------------------------------------------------------------
# Completion output
# ---------------------------------------------------------------------------

declare -a _ACTIONABLE_WARNINGS=()

print_completion() {
  printf "\n"
  for warning in "${_ACTIONABLE_WARNINGS[@]}"; do
    log_warn "$warning"
  done
  [[ ${#_ACTIONABLE_WARNINGS[@]} -gt 0 ]] && printf "\n"
  printf "  ${_GREEN}${_BOLD}✓ Done in %ss${_RST} ${_DIM}— happy hacking!${_RST}\n" "$SECONDS"
  if $_HAD_DOTFILES; then
    printf "\n  ${_DIM}Next → run${_RST} ${_BOLD}reload!${_RST} ${_DIM}to apply changes, or open a new terminal${_RST}\n\n"
  else
    printf "\n  ${_DIM}Next →${_RST} ${_BOLD}source ~/.zshrc${_RST} ${_DIM}or open a new terminal${_RST}\n\n"
  fi
}

# ---------------------------------------------------------------------------
# Traps
# ---------------------------------------------------------------------------

_current_phase=""

_on_error() {
  _spinner_cleanup
  log_error_context "$LOGFILE" "$_current_phase"
  if [[ "$_current_phase" == "Installing Software" ]] \
     && [[ -x "$DOTFILES_ROOT/script/brew-health" ]]; then
    printf "\n"
    "$DOTFILES_ROOT/script/brew-health" || true
  fi
}

_on_exit() {
  _spinner_cleanup
}

trap '_on_error' ERR
trap '_on_exit' EXIT

# ---------------------------------------------------------------------------
# Init
# ---------------------------------------------------------------------------

: > "$LOGFILE"  # Truncate log file

log_header "$DOTFILES_ROOT"

# ---------------------------------------------------------------------------
# Phase 1: Preflight
# ---------------------------------------------------------------------------

_current_phase="Preflight"

if $DRY_RUN; then
  log_phase "1/5" "Preflight"
  log_info "Dry run — previewing changes"
  printf "\n"

  local_symlinks="$(printf '%s\n' "$DOTFILES_ROOT"/*/*.symlink 2>/dev/null | wc -l | tr -d ' ')"

  if $SKIP_GIT; then
    log_skip "Git config (--skip-git)"
  else
    log_info "Would configure git (if needed)"
  fi
  log_info "Would link $local_symlinks symlink files"
  if $SKIP_DEPS; then
    log_skip "Installing Software (--skip-deps)"
  elif $IS_MACOS; then
    log_info "Would install Homebrew packages"
  else
    log_skip "Installing Software (not macOS)"
  fi
  log_info "Would run topic install scripts"
  printf "\n"
  exit 0
fi

phase_start "1/5" "Preflight"

_preflight_detail=""

phase_update "checking git"
if ! command -v git &>/dev/null; then
  phase_end fail "git not found"
  exit 1
fi
_preflight_detail="git ✓"

if $IS_MACOS; then
  phase_update "checking homebrew"
  if command -v brew &>/dev/null; then
    _preflight_detail+="  homebrew ✓"
  else
    _preflight_detail+="  homebrew pending"
  fi
fi

phase_end ok "$_preflight_detail"

# ---------------------------------------------------------------------------
# Phase 2: Git config
# ---------------------------------------------------------------------------

_current_phase="Git config"

if $SKIP_GIT; then
  phase_start "2/5" "Git Config"
  phase_end skip "--skip-git"
else
  phase_start "2/5" "Git Config"

  gitconfig_local="$DOTFILES_ROOT/git/gitconfig.local.symlink"

  if [[ -f "$gitconfig_local" ]]; then
    phase_end ok "already configured"
  elif [[ "$INTERACTIVE" != true ]]; then
    phase_end warn "skipped (non-interactive)"
  else
    phase_pause

    # Detect defaults from existing global config
    default_name="$(git config --global user.name 2>/dev/null || true)"
    default_email="$(git config --global user.email 2>/dev/null || true)"

    git_authorname="$(prompt_user "Git author name?" "$default_name")"
    printf "\n"
    git_authoremail="$(prompt_user "Git author email?" "$default_email")"
    printf "\n"

    git_credential='cache'
    $IS_MACOS && git_credential='osxkeychain'

    cat > "$gitconfig_local" <<EOF
[user]
        name = $git_authorname
        email = $git_authoremail
[credential]
        helper = $git_credential
EOF

    phase_resume
    phase_end ok "configured"
  fi
fi

# ---------------------------------------------------------------------------
# Phase 3: Symlinks
# ---------------------------------------------------------------------------

_current_phase="Symlinks"
phase_start "3/5" "Symlinks"

_link_count=0
_skip_count=0
_backup_count=0

overwrite_all=false
backup_all=false
skip_all=false
_first_conflict=true

link_file() {
  local src="$1" dst="$2"

  local overwrite=false backup=false skip=false

  if [[ -f "$dst" ]] || [[ -d "$dst" ]] || [[ -L "$dst" ]]; then
    if [[ "$overwrite_all" == false ]] && [[ "$backup_all" == false ]] && [[ "$skip_all" == false ]]; then
      local current_src
      current_src="$(readlink "$dst" 2>/dev/null || true)"

      if [[ "$current_src" == "$src" ]]; then
        skip=true
      elif [[ "$INTERACTIVE" == true ]]; then
        phase_pause

        printf "\n"
        log_warn "File exists: $dst"
        if [[ -n "$current_src" ]]; then
          log_info "current → $current_src"
        fi
        printf "\n"

        local choice
        choice="$(prompt_choice "Action" "Skip" "Overwrite" "Backup")"
        printf "\n"

        # On first conflict, offer "apply to all"
        if [[ "$_first_conflict" == true ]]; then
          _first_conflict=false
          local apply_all
          apply_all="$(prompt_user "Apply to all remaining conflicts?" "N")"
          printf "\n"
          if [[ "$apply_all" =~ ^[yY] ]]; then
            case "$choice" in
              1) skip_all=true ;;
              2) overwrite_all=true ;;
              3) backup_all=true ;;
            esac
          fi
        fi

        phase_resume

        case "$choice" in
          2) overwrite=true ;;
          3) backup=true ;;
          *) skip=true ;;
        esac
      else
        # Non-interactive: auto-skip conflicts
        skip=true
      fi
    fi

    [[ "$overwrite" == false ]] && overwrite="$overwrite_all"
    [[ "$backup" == false ]]    && backup="$backup_all"
    [[ "$skip" == false ]]      && skip="$skip_all"

    if [[ "$overwrite" == true ]]; then
      rm -rf "$dst"
    fi

    if [[ "$backup" == true ]]; then
      mv "$dst" "${dst}.backup"
      _backup_count=$((_backup_count + 1))
    fi

    if [[ "$skip" == true ]]; then
      _skip_count=$((_skip_count + 1))
    fi
  fi

  if [[ "$skip" != true ]]; then
    ln -s "$src" "$dst"
    _link_count=$((_link_count + 1))
  fi
}

for src in "$DOTFILES_ROOT"/*/*.symlink; do
  [[ -e "$src" ]] || continue  # guard against empty glob
  dst="$HOME/.$(basename "${src%.*}")"
  phase_update "$(basename "${src%.*}")"
  link_file "$src" "$dst"
done

# Build symlink summary detail
_sym_parts=()
[[ $_link_count -gt 0 ]]   && _sym_parts+=("$_link_count linked")
[[ $_skip_count -gt 0 ]]   && _sym_parts+=("$_skip_count already in place")
[[ $_backup_count -gt 0 ]] && _sym_parts+=("$_backup_count backed up")
if [[ ${#_sym_parts[@]} -eq 0 ]]; then
  _sym_detail="nothing to do"
else
  _sym_detail=""
  for _i in "${!_sym_parts[@]}"; do
    [[ $_i -gt 0 ]] && _sym_detail+=", "
    _sym_detail+="${_sym_parts[$_i]}"
  done
fi

phase_end ok "$_sym_detail"

# ---------------------------------------------------------------------------
# Phase 4: Installing Software
# ---------------------------------------------------------------------------

_current_phase="Installing Software"

if $SKIP_DEPS; then
  phase_start "4/5" "Installing Software"
  phase_end skip "--skip-deps"
elif ! $IS_MACOS; then
  phase_start "4/5" "Installing Software"
  phase_end skip "not macOS"
else
  _phase_timer_start "Installing Software"

  if $VERBOSE; then
    log_phase "4/5" "Installing Software"
  else
    phase_start "4/5" "Installing Software"
    phase_end_deferred
  fi

  # --- Homebrew ---
  if ! command -v brew &>/dev/null; then
    if $VERBOSE; then
      log_info "Installing Homebrew..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
      log_success "Homebrew installed"
    else
      run_with_substep_spinner "installing homebrew" "$LOGFILE" \
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    # Ensure brew is on PATH for the rest of this script
    if [[ -x "/opt/homebrew/bin/brew" ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x "/usr/local/bin/brew" ]]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  else
    if ! $VERBOSE; then
      substep_log_success "homebrew ready"
    else
      log_skip "Homebrew already installed"
    fi
  fi

  # --- Cask skip detection ---
  # Save shell options — brew-skip-detect sets -euo pipefail which must not leak
  if [[ -f "$DOTFILES_ROOT/script/brew-skip-detect" ]]; then
    _saved_opts=$(set +o)
    source "$DOTFILES_ROOT/script/brew-skip-detect"
    eval "$_saved_opts"
  fi

  # --- Brew update / upgrade / bundle ---
  if $VERBOSE; then
    log_info "brew update..."
    brew update 2>&1 | tee -a "$LOGFILE"
    log_success "brew update"

    log_info "brew upgrade..."
    if brew upgrade 2>&1 | tee -a "$LOGFILE"; then
      log_success "brew upgrade"
    else
      _upgrade_tail="$(tail -n 30 "$LOGFILE")"
      if echo "$_upgrade_tail" | grep -qE 'has been disabled|is not there|Permission denied|locked'; then
        log_error "brew upgrade (see ${LOGFILE##*/} for details)"
      else
        log_warn "brew upgrade (some packages skipped)"
      fi
    fi

    log_info "brew bundle..."
    _log_lines_before=$(wc -l < "$LOGFILE" 2>/dev/null || echo 0)
    brew bundle --file="$DOTFILES_ROOT/Brewfile" 2>&1 | tee -a "$LOGFILE"
    log_success "brew bundle"
  else
    run_with_substep_spinner "brew update" "$LOGFILE" \
      brew update

    # brew upgrade exits nonzero for both benign (nothing to upgrade) and real
    # failures (disabled formula, missing cask app, permissions). Inspect the
    # log to distinguish them.
    substep_start "brew upgrade"
    if brew upgrade >> "$LOGFILE" 2>&1; then
      substep_stop ok "brew upgrade"
    else
      _upgrade_tail="$(tail -n 30 "$LOGFILE")"
      if echo "$_upgrade_tail" | grep -qE 'has been disabled|is not there|Permission denied|locked'; then
        substep_stop fail "brew upgrade (errors in ${LOGFILE##*/})"
      else
        substep_stop warn "brew upgrade (some packages skipped)"
      fi
    fi

    _log_lines_before=$(wc -l < "$LOGFILE" 2>/dev/null || echo 0)
    run_with_substep_streaming_spinner "brew bundle" "$LOGFILE" \
      brew bundle --file="$DOTFILES_ROOT/Brewfile"
  fi

  # --- Build brew bundle summary from log ---
  _brew_installed=0
  _brew_upgraded=0
  _brew_using=0
  while IFS= read -r _line; do
    case "$_line" in
      Installing\ *) _brew_installed=$((_brew_installed + 1)) ;;
      Upgrading\ *)  _brew_upgraded=$((_brew_upgraded + 1)) ;;
      Using\ *)      _brew_using=$((_brew_using + 1)) ;;
    esac
  done < <(tail -n +"$((_log_lines_before + 1))" "$LOGFILE")

  _brew_summary=""
  if (( _brew_installed > 0 )); then
    _brew_summary="${_brew_installed} installed"
  fi
  if (( _brew_upgraded > 0 )); then
    [[ -n "$_brew_summary" ]] && _brew_summary+=", "
    _brew_summary+="${_brew_upgraded} upgraded"
  fi
  if [[ -z "$_brew_summary" ]]; then
    _brew_summary="all up to date"
  fi

  if $VERBOSE; then
    log_success "$_brew_summary"
  else
    phase_resolve ok "$_brew_summary"
  fi
fi

# ---------------------------------------------------------------------------
# Phase 5: Topic Install Scripts
# ---------------------------------------------------------------------------

_current_phase="Install Scripts"

_phase_timer_start "Install Scripts"

if $VERBOSE; then
  log_phase "5/5" "Install Scripts"
else
  phase_start "5/5" "Install Scripts"
  phase_end_deferred
fi

_install_count=0
while IFS= read -r -d '' installer; do
  if $VERBOSE; then
    log_info "Running ${installer#"$DOTFILES_ROOT"/}..."
    sh -c "$installer" 2>&1 | tee -a "$LOGFILE"
  else
    run_with_substep_spinner "${installer#"$DOTFILES_ROOT"/}" "$LOGFILE" \
      sh -c "$installer"
  fi
  _install_count=$((_install_count + 1))
done < <(find "$DOTFILES_ROOT" -name install.sh -not -path '*.git*' -print0)

# --- Drift check ---
# Count brew-installed packages not in Brewfile (fast, local)
if $IS_MACOS && ! $SKIP_DEPS; then
  if ! $VERBOSE; then
    substep_start "drift check"
  fi

  _audit_count=0
  _ignore_file="$HOME/.brew-audit-ignore"
  _drift_skipped=false

  if _brew_leaves="$(brew leaves 2>&1)"; then
    while IFS= read -r leaf; do
      [[ -z "$leaf" ]] && continue
      [[ -f "$_ignore_file" ]] && grep -qx "$leaf" "$_ignore_file" 2>/dev/null && continue
      if ! grep -qx "brew '$leaf'" "$DOTFILES_ROOT/Brewfile"; then
        _audit_count=$((_audit_count + 1))

      fi
    done <<< "$_brew_leaves"
  else
    _drift_skipped=true
  fi

  if _brew_casks="$(brew list --cask 2>&1)"; then
    while IFS= read -r cask; do
      [[ -z "$cask" ]] && continue
      echo " ${HOMEBREW_BUNDLE_CASK_SKIP:-} " | grep -q " $cask " && continue
      [[ -f "$_ignore_file" ]] && grep -qx "$cask" "$_ignore_file" 2>/dev/null && continue
      if ! grep -qx "cask '$cask'" "$DOTFILES_ROOT/Brewfile"; then
        _audit_count=$((_audit_count + 1))

      fi
    done <<< "$_brew_casks"
  else
    _drift_skipped=true
  fi

  # Collect expected taps from Brewfile
  if ! $_drift_skipped; then
    _expected_taps=()
    while IFS= read -r _tap_line; do
      _expected_taps+=("$_tap_line")
    done < <(grep "^tap " "$DOTFILES_ROOT/Brewfile" | sed "s/tap '\\(.*\\)'/\\1/")

    if _installed_taps="$(brew tap 2>&1)"; then
      while IFS= read -r _tap; do
        [[ -z "$_tap" ]] && continue
        # Skip implicit taps
        [[ "$_tap" == "homebrew/core" || "$_tap" == "homebrew/cask" || "$_tap" == "homebrew/bundle" ]] && continue
        [[ -f "$_ignore_file" ]] && grep -qx "$_tap" "$_ignore_file" 2>/dev/null && continue
        _is_expected=false
        for _t in "${_expected_taps[@]:-}"; do
          [[ "$_t" == "$_tap" ]] && { _is_expected=true; break; }
        done
        if ! $_is_expected; then
          _audit_count=$((_audit_count + 1))

        fi
      done <<< "$_installed_taps"
    else
      _drift_skipped=true
    fi
  fi

  if $_drift_skipped; then
    _ACTIONABLE_WARNINGS+=("drift check skipped: brew query failed (Homebrew may be broken)")
  elif [[ $_audit_count -gt 0 ]]; then
    _ACTIONABLE_WARNINGS+=("$_audit_count packages not in Brewfile — run ${_BOLD}script/brew-audit${_RST}")
  fi

  if $VERBOSE; then
    if $_drift_skipped; then
      log_warn "drift check skipped: brew query failed (Homebrew may be broken)"
    elif [[ $_audit_count -gt 0 ]]; then
      log_warn "$_audit_count packages not in Brewfile — run ${_BOLD}script/brew-audit${_RST}"
    fi
  else
    if $_drift_skipped; then
      substep_stop warn "drift check (skipped — brew query failed)"
    elif [[ $_audit_count -gt 0 ]]; then
      substep_stop warn "drift check ($_audit_count untracked)"
    else
      substep_stop ok "drift check"
    fi
  fi
fi

if $VERBOSE; then
  if [[ $_install_count -gt 0 ]]; then
    log_success "install scripts ($_install_count)"
  fi
else
  _install_detail="$_install_count completed"
  phase_resolve ok "$_install_detail"
fi

_current_phase=""
print_completion
