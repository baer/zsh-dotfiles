#!/usr/bin/env bash
#
# bootstrap — first-time dotfiles setup
#
# Links dotfiles to $HOME, configures git, and installs dependencies.
# Safe to re-run: skips anything already in place.

set -euo pipefail

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
LOGFILE="$DOTFILES_ROOT/.bootstrap.log"

# shellcheck source=lib/output.sh
source "$DOTFILES_ROOT/script/lib/output.sh"

# ---------------------------------------------------------------------------
# Flags
# ---------------------------------------------------------------------------

DRY_RUN=false
SKIP_DEPS=false
SKIP_GIT=false
VERBOSE=false

usage() {
  cat <<EOF
Usage: script/bootstrap [options]

Sets up this machine from scratch — symlinks dotfiles, configures git,
and installs Homebrew packages.

Options:
  --help        Show this message
  --dry-run     Preview what would happen without changing anything
  --skip-git    Skip git config setup
  --skip-deps   Skip Homebrew and dependency installation
  --verbose     Show full command output instead of spinners
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)      usage ;;
    --dry-run)   DRY_RUN=true ;;
    --skip-deps) SKIP_DEPS=true ;;
    --skip-git)  SKIP_GIT=true ;;
    --verbose)   VERBOSE=true ;;
    *)
      log_error "Unknown option: $1"
      usage
      ;;
  esac
  shift
done

# ---------------------------------------------------------------------------
# Environment detection
# ---------------------------------------------------------------------------

IS_MACOS=false
[[ "$(uname -s)" == "Darwin" ]] && IS_MACOS=true

# ---------------------------------------------------------------------------
# Summary tracking (structured)
# ---------------------------------------------------------------------------

declare -a _SUM_STATUS=()
declare -a _SUM_LABEL=()
declare -a _SUM_DETAIL=()
declare -a _SUM_TIME=()

summary_add() {
  _SUM_STATUS+=("$1")
  _SUM_LABEL+=("$2")
  _SUM_DETAIL+=("$3")
  _SUM_TIME+=("${4:-}")
}

print_summary() {
  log_summary_box _SUM_STATUS _SUM_LABEL _SUM_DETAIL _SUM_TIME "${SECONDS}s"
  log_celebration
}

# ---------------------------------------------------------------------------
# Traps
# ---------------------------------------------------------------------------

_current_phase=""

_on_error() {
  _spinner_cleanup
  log_error_context "$LOGFILE" "$_current_phase"
}

_on_exit() {
  local rc=$?
  _spinner_cleanup
  if [[ $rc -eq 0 ]] && [[ ${#_SUM_STATUS[@]} -gt 0 ]]; then
    print_summary
  fi
}

trap '_on_error' ERR
trap '_on_exit' EXIT

# ---------------------------------------------------------------------------
# Init
# ---------------------------------------------------------------------------

: > "$LOGFILE"  # Truncate log file

log_header "$DOTFILES_ROOT"

# ---------------------------------------------------------------------------
# Phase 1: Preflight
# ---------------------------------------------------------------------------

_current_phase="Preflight"
log_phase "1/4" "Preflight"

if ! command -v git &>/dev/null; then
  log_error "git is not installed"
  exit 1
fi
log_success "git found"

if $IS_MACOS; then
  if command -v brew &>/dev/null; then
    log_success "homebrew found"
  else
    log_info "homebrew not found — will install in phase 4"
  fi
fi

if $DRY_RUN; then
  log_info "Dry run — previewing changes"
  printf "\n"

  local_symlinks="$(printf '%s\n' "$DOTFILES_ROOT"/*/*.symlink 2>/dev/null | wc -l | tr -d ' ')"

  if $SKIP_GIT; then
    log_skip "Git config (--skip-git)"
  else
    log_info "Would configure git (if needed)"
  fi
  log_info "Would link $local_symlinks symlink files"
  if $SKIP_DEPS; then
    log_skip "Dependencies (--skip-deps)"
  elif $IS_MACOS; then
    log_info "Would install Homebrew packages"
  else
    log_skip "Dependencies (not macOS)"
  fi
  printf "\n"
  exit 0
fi

# ---------------------------------------------------------------------------
# Phase 2: Git config
# ---------------------------------------------------------------------------

_current_phase="Git config"

if $SKIP_GIT; then
  summary_add skip "Git config" "skipped (--skip-git)" "<1s"
else
  log_phase "2/4" "Git Config"

  gitconfig_local="$DOTFILES_ROOT/git/gitconfig.local.symlink"

  if [[ -f "$gitconfig_local" ]]; then
    log_skip "git/gitconfig.local.symlink already exists"
    summary_add ok "Git config" "already configured" "$(_phase_timer_elapsed "Git Config")"
  elif [[ "$INTERACTIVE" != true ]]; then
    log_warn "Skipping git config — requires interactive terminal"
    summary_add warn "Git config" "skipped (non-interactive)" "$(_phase_timer_elapsed "Git Config")"
  else
    # Detect defaults from existing global config
    default_name="$(git config --global user.name 2>/dev/null || true)"
    default_email="$(git config --global user.email 2>/dev/null || true)"

    git_authorname="$(prompt_user "Git author name?" "$default_name")"
    printf "\n"
    git_authoremail="$(prompt_user "Git author email?" "$default_email")"
    printf "\n"

    git_credential='cache'
    $IS_MACOS && git_credential='osxkeychain'

    cat > "$gitconfig_local" <<EOF
[user]
        name = $git_authorname
        email = $git_authoremail
[credential]
        helper = $git_credential
EOF

    log_success "Created git/gitconfig.local.symlink"
    summary_add ok "Git config" "configured" "$(_phase_timer_elapsed "Git Config")"
  fi
fi

# ---------------------------------------------------------------------------
# Phase 3: Symlinks
# ---------------------------------------------------------------------------

_current_phase="Symlinks"
log_phase "3/4" "Symlinks"

_link_count=0
_skip_count=0
_backup_count=0

overwrite_all=false
backup_all=false
skip_all=false
_first_conflict=true

link_file() {
  local src="$1" dst="$2"

  local overwrite=false backup=false skip=false

  if [[ -f "$dst" ]] || [[ -d "$dst" ]] || [[ -L "$dst" ]]; then
    if [[ "$overwrite_all" == false ]] && [[ "$backup_all" == false ]] && [[ "$skip_all" == false ]]; then
      local current_src
      current_src="$(readlink "$dst" 2>/dev/null || true)"

      if [[ "$current_src" == "$src" ]]; then
        skip=true
      elif [[ "$INTERACTIVE" == true ]]; then
        printf "\n"
        log_warn "File exists: $dst"
        if [[ -n "$current_src" ]]; then
          log_info "current → $current_src"
        fi
        printf "\n"

        local choice
        choice="$(prompt_choice "Action" "Skip" "Overwrite" "Backup")"
        printf "\n"

        # On first conflict, offer "apply to all"
        if [[ "$_first_conflict" == true ]]; then
          _first_conflict=false
          local apply_all
          apply_all="$(prompt_user "Apply to all remaining conflicts?" "N")"
          printf "\n"
          if [[ "$apply_all" =~ ^[yY] ]]; then
            case "$choice" in
              1) skip_all=true ;;
              2) overwrite_all=true ;;
              3) backup_all=true ;;
            esac
          fi
        fi

        case "$choice" in
          2) overwrite=true ;;
          3) backup=true ;;
          *) skip=true ;;
        esac
      else
        # Non-interactive: auto-skip conflicts
        skip=true
      fi
    fi

    [[ "$overwrite" == false ]] && overwrite="$overwrite_all"
    [[ "$backup" == false ]]    && backup="$backup_all"
    [[ "$skip" == false ]]      && skip="$skip_all"

    if [[ "$overwrite" == true ]]; then
      rm -rf "$dst"
    fi

    if [[ "$backup" == true ]]; then
      mv "$dst" "${dst}.backup"
      _backup_count=$((_backup_count + 1))
    fi

    if [[ "$skip" == true ]]; then
      _skip_count=$((_skip_count + 1))
    fi
  fi

  if [[ "$skip" != true ]]; then
    ln -s "$src" "$dst"
    _link_count=$((_link_count + 1))
  fi
}

for src in "$DOTFILES_ROOT"/*/*.symlink; do
  [[ -e "$src" ]] || continue  # guard against empty glob
  dst="$HOME/.$(basename "${src%.*}")"
  link_file "$src" "$dst"
done

# Build symlink summary detail
_sym_parts=()
[[ $_link_count -gt 0 ]]   && _sym_parts+=("$_link_count linked")
[[ $_skip_count -gt 0 ]]   && _sym_parts+=("$_skip_count skipped")
[[ $_backup_count -gt 0 ]] && _sym_parts+=("$_backup_count backed up")
if [[ ${#_sym_parts[@]} -eq 0 ]]; then
  _sym_detail="nothing to do"
else
  _sym_detail=""
  for _i in "${!_sym_parts[@]}"; do
    [[ $_i -gt 0 ]] && _sym_detail+=", "
    _sym_detail+="${_sym_parts[$_i]}"
  done
fi

if [[ $_link_count -gt 0 ]]; then
  log_success "$_link_count symlinks created"
fi
if [[ $_skip_count -gt 0 ]]; then
  log_skip "$_skip_count already in place"
fi

summary_add ok "Symlinks" "$_sym_detail" "$(_phase_timer_elapsed "Symlinks")"

# ---------------------------------------------------------------------------
# Phase 4: Dependencies
# ---------------------------------------------------------------------------

_current_phase="Dependencies"

if $SKIP_DEPS; then
  summary_add skip "Dependencies" "skipped (--skip-deps)" "<1s"
elif ! $IS_MACOS; then
  summary_add skip "Dependencies" "skipped (not macOS)" "<1s"
else
  log_phase "4/4" "Dependencies"

  # --- Homebrew ---
  if ! command -v brew &>/dev/null; then
    if $VERBOSE; then
      log_info "Installing Homebrew..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
      log_success "Homebrew installed"
    else
      run_with_spinner "Installing Homebrew" "$LOGFILE" \
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    # Ensure brew is on PATH for the rest of this script
    if [[ -x "/opt/homebrew/bin/brew" ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x "/usr/local/bin/brew" ]]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  else
    log_skip "Homebrew already installed"
  fi

  # --- Cask skip detection ---
  if [[ -f "$DOTFILES_ROOT/script/brew-skip-detect" ]]; then
    source "$DOTFILES_ROOT/script/brew-skip-detect"
  fi

  # --- Brew update / upgrade / bundle ---
  if $VERBOSE; then
    log_info "brew update..."
    brew update 2>&1 | tee -a "$LOGFILE"
    log_success "brew update"

    log_info "brew upgrade..."
    brew upgrade 2>&1 | tee -a "$LOGFILE"
    log_success "brew upgrade"

    log_info "brew bundle..."
    brew bundle --file="$DOTFILES_ROOT/Brewfile" --no-lock 2>&1 | tee -a "$LOGFILE"
    log_success "brew bundle"
  else
    run_with_spinner "brew update" "$LOGFILE" \
      brew update

    # brew upgrade can "fail" (exit 1) when there's nothing to upgrade
    spinner_start "brew upgrade"
    if brew upgrade >> "$LOGFILE" 2>&1; then
      spinner_stop ok "brew upgrade"
    else
      spinner_stop warn "brew upgrade (some packages skipped)"
    fi

    run_with_streaming_spinner "brew bundle" "$LOGFILE" \
      brew bundle --file="$DOTFILES_ROOT/Brewfile" --no-lock
  fi

  summary_add ok "Dependencies" "installed" "$(_phase_timer_elapsed "Dependencies")"

  # --- Topic install scripts ---
  _install_count=0
  while IFS= read -r -d '' installer; do
    [[ "$installer" == *"homebrew/install.sh" ]] && continue  # already handled above
    if $VERBOSE; then
      log_info "Running ${installer#"$DOTFILES_ROOT"/}..."
      sh -c "$installer" 2>&1 | tee -a "$LOGFILE"
    else
      sh -c "$installer" >> "$LOGFILE" 2>&1
    fi
    _install_count=$((_install_count + 1))
  done < <(find "$DOTFILES_ROOT" -name install.sh -not -path '*.git*' -print0)

  if [[ $_install_count -gt 0 ]]; then
    log_success "$_install_count install scripts run"
  fi
fi
