#!/usr/bin/env bash
#
# localrc — sync the repo-managed block in ~/.localrc with documented overrides

set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

# shellcheck source=lib/term.sh
source "$DOTFILES_ROOT/script/lib/term.sh"
# shellcheck source=lib/log.sh
source "$DOTFILES_ROOT/script/lib/log.sh"
# shellcheck source=lib/localrc-registry.sh
source "$DOTFILES_ROOT/script/lib/localrc-registry.sh"
# shellcheck source=lib/localrc.sh
source "$DOTFILES_ROOT/script/lib/localrc.sh"

CHECK_ONLY=false

usage() {
  local code="${1:-0}"
  cat <<EOF
Usage: script/localrc [options]

Sync the repo-managed block in ~/.localrc. Creates the file with a documented
template if it doesn't exist; otherwise re-renders the managed block, preserving
any \`export\` lines you've uncommented inside it.

Options:
  --check   Audit only; exit non-zero if a sync would change ~/.localrc
  --help    Show this message

To override a default, edit ~/.localrc and uncomment the relevant export line.
Anything outside the managed block is yours — secrets, manual exports, etc.
EOF
  exit "$code"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check) CHECK_ONLY=true ;;
    --help) usage ;;
    *)
      log_error "Unknown option: $1"
      usage 1
      ;;
  esac
  shift
done

LOCALRC_FILE="$(_localrc_path)"

_print_var_status() {
  local var="$1" file="$2"
  local managed unmanaged default desc status detail
  managed="$(_localrc_get_managed_value "$var" "$file" 2>/dev/null || true)"
  unmanaged="$(_localrc_get_unmanaged_value "$var" "$file" 2>/dev/null || true)"
  default="$(_localrc_registry_default "$var" 2>/dev/null || true)"
  desc="$(_localrc_registry_description "$var")"

  if [[ -n "$unmanaged" ]]; then
    status="$_WARN"
    detail="manual export outside managed block"
  elif [[ -n "$managed" ]]; then
    status="$_CHECK"
    detail="\"$managed\""
  elif [[ -n "$default" ]]; then
    status="$_INFO"
    detail="default $default"
  else
    status="$_INFO"
    detail="not set"
  fi

  printf "  %s %-26s %s ${_DIM}(%s)${_RST}\n" "$status" "$var" "$desc" "$detail"
}

_print_status_table() {
  local group label var
  while IFS= read -r group; do
    label="$(_localrc_registry_group_label "$group")"
    printf "\n  ${_BOLD}%s${_RST}\n" "$label"
    while IFS= read -r var; do
      _print_var_status "$var" "$LOCALRC_FILE"
    done < <(_localrc_registry_vars_in "$group")
  done < <(_localrc_registry_groups)
}

_audit_drift() {
  # Returns 0 if a sync would not change the file, 1 otherwise.
  local tmp
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' RETURN

  if [[ -f "$LOCALRC_FILE" ]]; then
    cp "$LOCALRC_FILE" "$tmp"
  fi
  _localrc_render_managed_block "$tmp"

  if [[ ! -f "$LOCALRC_FILE" ]]; then
    return 1
  fi

  if diff -q "$LOCALRC_FILE" "$tmp" >/dev/null 2>&1; then
    return 0
  fi

  return 1
}

if $CHECK_ONLY; then
  if _audit_drift; then
    exit 0
  else
    exit 1
  fi
fi

printf "\n  ${_BOLD}localrc${_RST}\n\n"
log_info "Syncing managed block in ${LOCALRC_FILE/#$HOME/~}"

_pre_existed=false
_pre_copy=""
if [[ -f "$LOCALRC_FILE" ]]; then
  _pre_existed=true
  _pre_copy="$(mktemp)"
  trap 'rm -f "$_pre_copy"' EXIT
  cp "$LOCALRC_FILE" "$_pre_copy"
fi

_localrc_render_managed_block "$LOCALRC_FILE"

_print_status_table

printf "\n"
if ! $_pre_existed; then
  log_success "Created ${LOCALRC_FILE/#$HOME/~} with documented overrides"
elif ! diff -q "$_pre_copy" "$LOCALRC_FILE" >/dev/null 2>&1; then
  log_success "Updated managed block in ${LOCALRC_FILE/#$HOME/~}"
else
  log_success "Managed block already in sync"
fi
log_info "Edit ${LOCALRC_FILE/#$HOME/~} and uncomment any \`export\` line to override a default"
log_info "Anything outside the managed block is yours — secrets, manual exports, etc."

# Warn if any registry var has a manual export outside the managed block
_unmanaged_warned=false
while IFS= read -r var; do
  if [[ -n "$(_localrc_get_unmanaged_value "$var" "$LOCALRC_FILE" 2>/dev/null || true)" ]]; then
    if ! $_unmanaged_warned; then
      printf "\n"
      log_warn "Some repo-recognized vars are exported outside the managed block:"
      _unmanaged_warned=true
    fi
    printf "    %s\n" "$var"
  fi
done < <(_localrc_registry_all_vars)
$_unmanaged_warned && log_info "Move them inside the managed block (uncomment in place) to let script/localrc track them"
exit 0
