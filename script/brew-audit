#!/usr/bin/env bash
#
# brew-audit
#
# Detects Brewfile drift (packages installed via brew but not listed in
# the Brewfile) and manually installed apps that could be adopted into
# Homebrew management. Presents a single fzf triage table for
# interactive review.

set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)
LOGFILE="$DOTFILES_ROOT/.brew-audit.log"

# shellcheck source=lib/term.sh
source "$DOTFILES_ROOT/script/lib/term.sh"
# shellcheck source=lib/log.sh
source "$DOTFILES_ROOT/script/lib/log.sh"
# shellcheck source=lib/spinner.sh
source "$DOTFILES_ROOT/script/lib/spinner.sh"
# shellcheck source=lib/prompt.sh
source "$DOTFILES_ROOT/script/lib/prompt.sh"
# shellcheck source=lib/adopt.sh
source "$DOTFILES_ROOT/script/lib/adopt.sh"
# shellcheck source=lib/brewfile.sh
source "$DOTFILES_ROOT/script/lib/brewfile.sh"
# shellcheck source=lib/skip-lists.sh
source "$DOTFILES_ROOT/script/lib/skip-lists.sh"
# shellcheck source=lib/drift.sh
source "$DOTFILES_ROOT/script/lib/drift.sh"
# shellcheck source=lib/cask-detect.sh
source "$DOTFILES_ROOT/script/lib/cask-detect.sh"

# Source localrc to pick up HOMEBREW_BUNDLE_CASK_SKIP
# shellcheck disable=SC1091
[[ -f "$HOME/.localrc" ]] && source "$HOME/.localrc"

IGNORE_FILE="$HOME/.brew-audit-ignore"
export AUDIT_IGNORE_FILE="$IGNORE_FILE"
BREWFILE="$DOTFILES_ROOT/Brewfile"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_remove_tap() {
  local tap="$1"
  spinner_start "brew untap $tap"
  if brew untap "$tap" >> "$LOGFILE" 2>&1; then
    spinner_stop ok "brew untap $tap"
  else
    spinner_stop fail "brew untap $tap (see .brew-audit.log)"
  fi
}

_remove_formula() {
  local formula="$1"
  local dependents
  dependents="$(brew uses --installed "$formula" 2>/dev/null || true)"
  if [[ -n "$dependents" ]]; then
    log_warn "Other packages depend on $formula:"
    printf "    %s\n" $dependents
    local _confirm
    _confirm="$(prompt_user "Remove anyway? [y/N]" "n")"
    if [[ ! "$_confirm" =~ ^[yY]$ ]]; then
      log_info "Skipped $formula"
      return 0
    fi
  fi
  spinner_start "brew uninstall $formula"
  if brew uninstall "$formula" >> "$LOGFILE" 2>&1; then
    spinner_stop ok "brew uninstall $formula"
  else
    spinner_stop fail "brew uninstall $formula (see .brew-audit.log)"
  fi
}

_remove_cask() {
  local cask="$1"
  spinner_start "brew uninstall --cask $cask"
  if brew uninstall --cask "$cask" >> "$LOGFILE" 2>&1; then
    spinner_stop ok "brew uninstall --cask $cask"
  else
    spinner_stop fail "brew uninstall --cask $cask (see .brew-audit.log)"
  fi
}

_add_to_ignore() {
  local pkg="$1"
  if [[ ! -f "$IGNORE_FILE" ]]; then
    printf "# brew-audit-ignore\n#\n# Packages listed here are excluded from brew-audit drift detection.\n# Add formula or cask names, one per line.\n" > "$IGNORE_FILE"
  fi
  echo "$pkg" >> "$IGNORE_FILE"
  log_success "Added $pkg to ignore list"
}

# ---------------------------------------------------------------------------
# Traps
# ---------------------------------------------------------------------------

_on_exit() { _spinner_cleanup; }
trap '_on_exit' EXIT

# ---------------------------------------------------------------------------
# Stage 1: Collection
# ---------------------------------------------------------------------------

: > "$LOGFILE"

printf "\n  ${_BOLD}brew-audit${_RST}\n\n"

# Drift collection
mapfile -t drift_taps < <(_collect_drift_taps)
mapfile -t drift_formulae < <(_collect_drift_formulae)
mapfile -t drift_casks < <(_collect_drift_casks)

drift_mas=()
if command -v mas &>/dev/null; then
  while IFS= read -r _drift_line; do
    [[ -z "$_drift_line" ]] && continue
    _mas_id="${_drift_line%% *}"
    _mas_name="${_drift_line#* }"
    drift_mas+=("${_mas_id}:${_mas_name}")
  done < <(_collect_drift_mas)
fi

_drift_count=$(( ${#drift_taps[@]} + ${#drift_formulae[@]} + ${#drift_casks[@]} + ${#drift_mas[@]} ))

if [[ $_drift_count -gt 0 ]]; then
  log_info "Collected drift: ${#drift_formulae[@]} formulae, ${#drift_casks[@]} casks, ${#drift_taps[@]} taps, ${#drift_mas[@]} mas"
fi

# Adoption scan (automatic, no prompt)
adoptable_casks=()
adoptable_apps=()

if [[ "$INTERACTIVE" == true ]]; then
  spinner_start "Scanning /Applications for adoptable apps"

  _brew_casks="$(brew list --cask 2>/dev/null || true)"

  while IFS= read -r app_dir; do
    app_name="$(basename "$app_dir")"
    [[ "$app_name" != *.app ]] && continue

    candidate="$(echo "${app_name%.app}" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')"
    [[ -z "$candidate" ]] && continue

    echo "$_brew_casks" | grep -qx "$candidate" && continue
    _is_audit_ignored "$candidate" && continue

    if brew info --cask "$candidate" > /dev/null 2>&1; then
      adoptable_casks+=("$candidate")
      adoptable_apps+=("$app_name")
    fi
  done < <(find /Applications -maxdepth 1 -name "*.app" -type d 2>/dev/null)

  spinner_stop ok "Scanned /Applications (${#adoptable_casks[@]} adoptable)"
fi

# Total items
_total=$(( _drift_count + ${#adoptable_casks[@]} ))

if [[ $_total -eq 0 ]]; then
  log_success "Brewfile is in sync — nothing to do"
  printf "\n"
  exit 0
fi

if [[ "$INTERACTIVE" != true ]]; then
  log_info "$_total packages not in Brewfile (run interactively to resolve)"
  exit 0
fi

# ---------------------------------------------------------------------------
# Stage 2: fzf Triage Table (placeholder)
# ---------------------------------------------------------------------------

printf "\n  TODO: fzf triage table with %d items\n\n" "$_total"

# ---------------------------------------------------------------------------
# Stage 3: Summary + Confirm + Execute (placeholder)
# ---------------------------------------------------------------------------

printf "  TODO: summary, confirm, execute\n"

printf "\n  ${_GREEN}${_BOLD}✓${_RST} ${_DIM}Done${_RST}\n\n"
