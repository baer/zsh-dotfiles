#!/usr/bin/env bash
#
# brew-audit
#
# Detects Brewfile drift (packages installed via brew but not listed in
# the Brewfile) and manually installed apps that could be adopted into
# Homebrew management. Presents a single fzf triage table for
# interactive review.

set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)
LOGFILE="$DOTFILES_ROOT/.brew-audit.log"

# shellcheck source=lib/term.sh
source "$DOTFILES_ROOT/script/lib/term.sh"
# shellcheck source=lib/log.sh
source "$DOTFILES_ROOT/script/lib/log.sh"
# shellcheck source=lib/spinner.sh
source "$DOTFILES_ROOT/script/lib/spinner.sh"
# shellcheck source=lib/prompt.sh
source "$DOTFILES_ROOT/script/lib/prompt.sh"
# shellcheck source=lib/adopt.sh
source "$DOTFILES_ROOT/script/lib/adopt.sh"
# shellcheck source=lib/brewfile.sh
source "$DOTFILES_ROOT/script/lib/brewfile.sh"
# shellcheck source=lib/skip-lists.sh
source "$DOTFILES_ROOT/script/lib/skip-lists.sh"
# shellcheck source=lib/drift.sh
source "$DOTFILES_ROOT/script/lib/drift.sh"
# shellcheck source=lib/cask-detect.sh
source "$DOTFILES_ROOT/script/lib/cask-detect.sh"

# Source localrc to pick up HOMEBREW_BUNDLE_CASK_SKIP
# shellcheck disable=SC1091
[[ -f "$HOME/.localrc" ]] && source "$HOME/.localrc"

IGNORE_FILE="$HOME/.brew-audit-ignore"
export AUDIT_IGNORE_FILE="$IGNORE_FILE"
BREWFILE="$DOTFILES_ROOT/Brewfile"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_remove_tap() {
  local tap="$1"
  spinner_start "brew untap $tap"
  if brew untap "$tap" >> "$LOGFILE" 2>&1; then
    spinner_stop ok "brew untap $tap"
  else
    spinner_stop fail "brew untap $tap (see .brew-audit.log)"
  fi
}

_remove_formula() {
  local formula="$1"
  local dependents
  dependents="$(brew uses --installed "$formula" 2>/dev/null || true)"
  if [[ -n "$dependents" ]]; then
    log_warn "Other packages depend on $formula:"
    printf "    %s\n" $dependents
    local _confirm
    _confirm="$(prompt_user "Remove anyway? [y/N]" "n")"
    if [[ ! "$_confirm" =~ ^[yY]$ ]]; then
      log_info "Skipped $formula"
      return 0
    fi
  fi
  spinner_start "brew uninstall $formula"
  if brew uninstall "$formula" >> "$LOGFILE" 2>&1; then
    spinner_stop ok "brew uninstall $formula"
  else
    spinner_stop fail "brew uninstall $formula (see .brew-audit.log)"
  fi
}

_remove_cask() {
  local cask="$1"
  spinner_start "brew uninstall --cask $cask"
  if brew uninstall --cask "$cask" >> "$LOGFILE" 2>&1; then
    spinner_stop ok "brew uninstall --cask $cask"
  else
    spinner_stop fail "brew uninstall --cask $cask (see .brew-audit.log)"
  fi
}

_add_to_ignore() {
  local pkg="$1"
  if [[ ! -f "$IGNORE_FILE" ]]; then
    printf "# brew-audit-ignore\n#\n# Packages listed here are excluded from brew-audit drift detection.\n# Add formula or cask names, one per line.\n" > "$IGNORE_FILE"
  fi
  echo "$pkg" >> "$IGNORE_FILE"
  log_success "Added $pkg to ignore list"
}

# ---------------------------------------------------------------------------
# Traps
# ---------------------------------------------------------------------------

_on_exit() { _spinner_cleanup; rm -f "${_STATE_FILE:-}"; }
trap '_on_exit' EXIT

# ---------------------------------------------------------------------------
# Stage 1: Collection
# ---------------------------------------------------------------------------

: > "$LOGFILE"

printf "\n  ${_BOLD}brew-audit${_RST}\n\n"

# Drift collection
mapfile -t drift_taps < <(_collect_drift_taps)
mapfile -t drift_formulae < <(_collect_drift_formulae)
mapfile -t drift_casks < <(_collect_drift_casks)

drift_mas=()
if command -v mas &>/dev/null; then
  while IFS= read -r _drift_line; do
    [[ -z "$_drift_line" ]] && continue
    _mas_id="${_drift_line%% *}"
    _mas_name="${_drift_line#* }"
    drift_mas+=("${_mas_id}:${_mas_name}")
  done < <(_collect_drift_mas)
fi

_drift_count=$(( ${#drift_taps[@]} + ${#drift_formulae[@]} + ${#drift_casks[@]} + ${#drift_mas[@]} ))

if [[ $_drift_count -gt 0 ]]; then
  log_info "Collected drift: ${#drift_formulae[@]} formulae, ${#drift_casks[@]} casks, ${#drift_taps[@]} taps, ${#drift_mas[@]} mas"
fi

# Adoption scan (automatic, no prompt)
adoptable_casks=()
adoptable_apps=()

if [[ "$INTERACTIVE" == true ]]; then
  spinner_start "Scanning /Applications for adoptable apps"

  _brew_casks="$(brew list --cask 2>/dev/null || true)"

  while IFS= read -r app_dir; do
    app_name="$(basename "$app_dir")"
    [[ "$app_name" != *.app ]] && continue

    candidate="$(echo "${app_name%.app}" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')"
    [[ -z "$candidate" ]] && continue

    echo "$_brew_casks" | grep -qx "$candidate" && continue
    _is_audit_ignored "$candidate" && continue

    if brew info --cask "$candidate" > /dev/null 2>&1; then
      adoptable_casks+=("$candidate")
      adoptable_apps+=("$app_name")
    fi
  done < <(find /Applications -maxdepth 1 -name "*.app" -type d 2>/dev/null)

  spinner_stop ok "Scanned /Applications (${#adoptable_casks[@]} adoptable)"
fi

# Total items
_total=$(( _drift_count + ${#adoptable_casks[@]} ))

if [[ $_total -eq 0 ]]; then
  log_success "Brewfile is in sync — nothing to do"
  printf "\n"
  exit 0
fi

if [[ "$INTERACTIVE" != true ]]; then
  log_info "$_total packages not in Brewfile (run interactively to resolve)"
  exit 0
fi

# ---------------------------------------------------------------------------
# State file for fzf triage
# ---------------------------------------------------------------------------

_STATE_FILE="$(mktemp)"

# Populate state file — one line per item, all default to "skip"
for t in "${drift_taps[@]}"; do
  printf 'skip\t%s\ttap\t\n' "$t" >> "$_STATE_FILE"
done
for f in "${drift_formulae[@]}"; do
  printf 'skip\t%s\tformula\t\n' "$f" >> "$_STATE_FILE"
done
for c in "${drift_casks[@]}"; do
  printf 'skip\t%s\tcask\t\n' "$c" >> "$_STATE_FILE"
done
for m in "${drift_mas[@]}"; do
  _mid="${m%%:*}"
  _mname="${m#*:}"
  printf 'skip\t%s\tmas\t%s\n' "$_mname" "$_mid" >> "$_STATE_FILE"
done
for i in "${!adoptable_casks[@]}"; do
  printf 'skip\t%s → %s\tadopt\t%s\n' "${adoptable_apps[$i]}" "${adoptable_casks[$i]}" "${adoptable_apps[$i]}" >> "$_STATE_FILE"
done

# Render the state file as colored lines for fzf
_render_triage() {
  while IFS=$'\t' read -r action pkg typ extra; do
    case "$action" in
      add)    printf '\033[32m[add]   \033[0m %-40s %s\n' "$pkg" "$typ" ;;
      remove) printf '\033[31m[remove]\033[0m %-40s %s\n' "$pkg" "$typ" ;;
      ignore) printf '\033[90m[ignore]\033[0m %-40s %s\n' "$pkg" "$typ" ;;
      skip)   printf '\033[90m[skip]  \033[0m %-40s %s\n' "$pkg" "$typ" ;;
    esac
  done < "$_STATE_FILE"
}

# Update one line's action in the state file (line_num is 0-based from fzf {n})
_update_action() {
  local line_num="$1" new_action="$2"
  local sed_line=$(( line_num + 1 ))
  # Block 'remove' for mas items
  if [[ "$new_action" == "remove" ]]; then
    local item_type
    item_type="$(awk -v ln="$sed_line" 'BEGIN{FS="\t"} NR==ln{print $3}' "$_STATE_FILE")"
    if [[ "$item_type" == "mas" ]]; then
      return 0
    fi
  fi
  awk -v ln="$sed_line" -v act="$new_action" 'BEGIN{FS=OFS="\t"} NR==ln{$1=act} 1' "$_STATE_FILE" > "$_STATE_FILE.tmp" && mv "$_STATE_FILE.tmp" "$_STATE_FILE"
}

export _STATE_FILE
export -f _render_triage _update_action

# ---------------------------------------------------------------------------
# Stage 2: fzf Triage Table
# ---------------------------------------------------------------------------

if ! command -v fzf > /dev/null 2>&1; then
  log_error "fzf is required for interactive review."
  printf "    Run ${_BOLD}script/bootstrap${_RST} to install it, or: ${_BOLD}brew install fzf${_RST}\n"
  exit 1
fi

_fzf_rc=0
_render_triage | fzf --ansi --no-sort --reverse \
  --header $'a:add  r:remove  i:ignore  s:skip  enter:confirm  esc:quit' \
  --header-first \
  --track --id-nth=2 \
  --bind "a:execute-silent(_update_action {n} add)+reload(_render_triage)+down" \
  --bind "r:execute-silent(_update_action {n} remove)+reload(_render_triage)+down" \
  --bind "i:execute-silent(_update_action {n} ignore)+reload(_render_triage)+down" \
  --bind "s:execute-silent(_update_action {n} skip)+reload(_render_triage)+down" \
  > /dev/null || _fzf_rc=$?

if [[ $_fzf_rc -eq 130 ]]; then
  # User pressed Esc or Ctrl-C
  printf "\n"
  exit 0
fi

# ---------------------------------------------------------------------------
# Stage 3: Summary + Confirm + Execute
# ---------------------------------------------------------------------------

# Read state file into action buckets
_add_items=()
_adopt_items=()
_remove_items=()
_ignore_items=()
_skip_items=()

while IFS=$'\t' read -r action pkg typ extra; do
  case "$action" in
    add)
      if [[ "$typ" == "adopt" ]]; then
        _adopt_items+=("$pkg"$'\t'"$extra")
      else
        _add_items+=("$pkg"$'\t'"$typ"$'\t'"$extra")
      fi
      ;;
    remove) _remove_items+=("$pkg"$'\t'"$typ") ;;
    ignore) _ignore_items+=("$pkg"$'\t'"$typ"$'\t'"$extra") ;;
    skip)   _skip_items+=("$pkg") ;;
  esac
done < "$_STATE_FILE"

# Print summary
printf "\n"
if [[ ${#_add_items[@]} -gt 0 ]]; then
  _names=()
  for item in "${_add_items[@]}"; do _names+=("${item%%$'\t'*}"); done
  printf "  ${_GREEN}Add (%d):${_RST}     %s\n" "${#_add_items[@]}" "$(IFS=', '; echo "${_names[*]}")"
fi
if [[ ${#_adopt_items[@]} -gt 0 ]]; then
  _names=()
  for item in "${_adopt_items[@]}"; do _names+=("${item%%$'\t'*}"); done
  printf "  ${_GREEN}Adopt (%d):${_RST}   %s\n" "${#_adopt_items[@]}" "$(IFS=', '; echo "${_names[*]}")"
fi
if [[ ${#_remove_items[@]} -gt 0 ]]; then
  _names=()
  for item in "${_remove_items[@]}"; do _names+=("${item%%$'\t'*}"); done
  printf "  ${_RED}Remove (%d):${_RST}  %s\n" "${#_remove_items[@]}" "$(IFS=', '; echo "${_names[*]}")"
fi
if [[ ${#_ignore_items[@]} -gt 0 ]]; then
  _names=()
  for item in "${_ignore_items[@]}"; do _names+=("${item%%$'\t'*}"); done
  printf "  ${_DIM}Ignore (%d):${_RST}  %s\n" "${#_ignore_items[@]}" "$(IFS=', '; echo "${_names[*]}")"
fi
if [[ ${#_skip_items[@]} -gt 0 ]]; then
  printf "  ${_DIM}Skip (%d)${_RST}\n" "${#_skip_items[@]}"
fi
printf "\n"

# Check if any actions to execute
_has_actions=$(( ${#_add_items[@]} + ${#_adopt_items[@]} + ${#_remove_items[@]} + ${#_ignore_items[@]} ))

if [[ $_has_actions -eq 0 ]]; then
  printf "  ${_DIM}No actions selected${_RST}\n"
  printf "\n  ${_GREEN}${_BOLD}✓${_RST} ${_DIM}Done${_RST}\n\n"
  exit 0
fi

# Confirm
_confirm="$(prompt_user "Proceed? [Y/n]" "y")"
if [[ "$_confirm" =~ ^[nN]$ ]]; then
  printf "\n"
  exit 0
fi
printf "\n"

# Execute: Adds (safe, no confirmation)
for item in "${_add_items[@]}"; do
  IFS=$'\t' read -r pkg typ extra <<< "$item"
  case "$typ" in
    tap)     _brewfile_insert "tap" "$pkg" ;;
    formula) _brewfile_insert "brew" "$pkg" ;;
    cask)    _brewfile_insert "cask" "$pkg" ;;
    mas)     _brewfile_insert "mas" "$pkg" "$extra" ;;
  esac
done

# Execute: Adoptions
for item in "${_adopt_items[@]}"; do
  IFS=$'\t' read -r display app_name <<< "$item"
  # Extract cask name from "AppName.app → cask-name" display format
  cask_name="${display##* → }"
  _adopt_cask "$cask_name" "$app_name" || true
done

# Execute: Removals
for item in "${_remove_items[@]}"; do
  IFS=$'\t' read -r pkg typ <<< "$item"
  case "$typ" in
    tap)     _remove_tap "$pkg" ;;
    formula) _remove_formula "$pkg" ;;
    cask)    _remove_cask "$pkg" ;;
  esac
done

# Execute: Ignores
for item in "${_ignore_items[@]}"; do
  IFS=$'\t' read -r pkg typ extra <<< "$item"
  if [[ "$typ" == "mas" ]]; then
    _add_to_ignore "$extra"
  else
    _add_to_ignore "$pkg"
  fi
done

printf "\n  ${_GREEN}${_BOLD}✓${_RST} ${_DIM}Done${_RST}\n\n"
