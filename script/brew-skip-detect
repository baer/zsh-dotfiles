#!/usr/bin/env bash
#
# brew-skip-detect
#
# Detects Brewfile casks that are already installed outside of Homebrew
# (e.g., by company MDM, Chef, or manual download) and offers to set
# HOMEBREW_BUNDLE_CASK_SKIP in ~/.localrc so `brew bundle` skips them.

set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)
BREWFILE="$DOTFILES_ROOT/Brewfile"

# shellcheck source=lib/output.sh
source "$DOTFILES_ROOT/script/lib/output.sh"
# shellcheck source=lib/brewfile.sh
source "$DOTFILES_ROOT/script/lib/brewfile.sh"
# shellcheck source=lib/skip-lists.sh
source "$DOTFILES_ROOT/script/lib/skip-lists.sh"
# shellcheck source=lib/cask-detect.sh
source "$DOTFILES_ROOT/script/lib/cask-detect.sh"

# Source localrc to pick up any existing skip list
# shellcheck disable=SC1091
[[ -f "$HOME/.localrc" ]] && source "$HOME/.localrc"

# Wrap body in a function so early returns actually stop execution when sourced
_brew_skip_detect_main() {

# Collect cask tokens from Brewfile
brewfile_casks=()
mapfile -t brewfile_casks < <(_brewfile_list_section "cask")

if [ ${#brewfile_casks[@]} -eq 0 ]; then
  # Nothing to report — no casks in Brewfile
  return 0
fi

# Get currently brew-managed casks
brew_managed=$(brew list --cask 2>/dev/null || true)

# Filter to only casks not managed by Homebrew
unmanaged_casks=()
for cask in "${brewfile_casks[@]}"; do
  if ! echo "$brew_managed" | grep -qx "$cask"; then
    unmanaged_casks+=("$cask")
  fi
done

if [ ${#unmanaged_casks[@]} -eq 0 ]; then
  # Nothing to report — all casks are brew-managed
  return 0
fi

# Filter out casks already in the skip list before expensive detection
if [ -n "${HOMEBREW_BUNDLE_CASK_SKIP:-}" ]; then
  filtered_casks=()
  for cask in "${unmanaged_casks[@]}"; do
    _is_cask_skipped "$cask" || filtered_casks+=("$cask")
  done
  if [ ${#filtered_casks[@]} -eq 0 ]; then
    substep_log_info "skipping casks installed outside Homebrew"
    return 0
  fi
  unmanaged_casks=("${filtered_casks[@]}")
fi

# Query brew for app artifact names in a single batch call, then detect
# which apps are already present on disk via a non-Homebrew install.
substep_log_info "checking ${#unmanaged_casks[@]} casks not managed by Homebrew"

skip_casks=()
skip_details=()

for cask in "${unmanaged_casks[@]}"; do
  if _is_cask_preinstalled "$cask"; then
    skip_casks+=("$cask")
    skip_details+=("$cask ($_DETECTED_APP_PATH)")
  fi
done

if [ ${#skip_casks[@]} -eq 0 ]; then
  return 0
fi

# Present results — mark cursor dirty since these lines are untracked
substep_mark_dirty
printf "\n"
log_warn "Found ${#skip_casks[@]} casks already installed outside Homebrew:"
for detail in "${skip_details[@]}"; do
  printf "    %s %s\n" "$_INFO" "$detail"
done
printf "\n"

if [[ "${INTERACTIVE:-true}" != true ]]; then
  # Non-interactive: auto-accept skip for all
  _skip_response=1
  log_info "Auto-accepting cask skip list (non-interactive)"
else
  _skip_response="$(prompt_choice "Action" "Skip all (add to skip list)" "Review individually" "Cancel")"
  printf "\n"
fi

case "$_skip_response" in
  3)
    log_info "Cancelled — no changes made"
    return 0
    ;;
  2)
    # Per-app review
    _final_skip_casks=()
    for i in "${!skip_casks[@]}"; do
      local cask="${skip_casks[$i]}"
      local detail="${skip_details[$i]}"
      printf "    %s\n" "$detail"
      local _app_response
      _app_response="$(prompt_choice "Action" "Skip (company-managed)" "Adopt into brew" "Decide later")"
      printf "\n"

      case "$_app_response" in
        1)
          _final_skip_casks+=("$cask")
          ;;
        2)
          # Adoption: find the app path and trash it
          # Extract app name from detail: "cask (App Name.app)" -> "App Name.app"
          local app_name=""
          app_name="$(echo "$detail" | sed 's/.*(\(.*\))/\1/')"

          # Check if running
          if [[ -n "$app_name" ]] && [[ "$app_name" != *"pkg:"* ]]; then
            local app_base="${app_name%.app}"
            if pgrep -fi "$app_base" > /dev/null 2>&1; then
              log_warn "$app_base is running. Please quit it before continuing."
              printf "    Press Enter when ready, or 's' to skip... "
              local _wait_response
              read -r _wait_response
              if [[ "$_wait_response" == "s" ]]; then
                log_info "Skipped $cask"
                continue
              fi
            fi

            # Trash the manual install
            local app_path="/Applications/$app_name"
            if [[ -d "$app_path" ]]; then
              if mv "$app_path" "$HOME/.Trash/" 2>/dev/null; then
                log_success "Moved $app_name to Trash"
              else
                log_error "Could not move $app_name to Trash (permissions?)"
                log_info "Skipping adoption of $cask"
                continue
              fi
            fi
          elif [[ "$app_name" == *"pkg:"* ]]; then
            log_warn "Package-based install detected for $cask — cannot auto-trash"
            log_info "Adding to skip list instead"
            _final_skip_casks+=("$cask")
            continue
          fi

          # Don't add to skip list — brew bundle will install it
          log_success "Adopted $cask — brew bundle will install it"
          ;;
        3)
          # Decide later — don't skip, don't adopt
          log_info "Deferred $cask"
          ;;
      esac
    done

    # Only write skip list if there are casks to skip
    if [[ ${#_final_skip_casks[@]} -eq 0 ]]; then
      if [[ -n "${HOMEBREW_BUNDLE_CASK_SKIP:-}" ]]; then
        log_info "No new casks to skip (existing skip list unchanged)"
      fi
      return 0
    fi
    skip_casks=("${_final_skip_casks[@]}")
    ;;
  *)
    # Skip all — current behavior
    ;;
esac

# Build skip line from remaining skip_casks
local skip_line="${skip_casks[*]}"

# Merge with existing skip list so we don't overwrite previously saved casks
if [ -n "${HOMEBREW_BUNDLE_CASK_SKIP:-}" ]; then
  skip_line="$HOMEBREW_BUNDLE_CASK_SKIP $skip_line"
fi

# Deduplicate the skip line
skip_line="$(echo "$skip_line" | tr ' ' '\n' | sort -u | tr '\n' ' ' | sed 's/ $//')"

# Write to ~/.localrc
local localrc="$HOME/.localrc"
local export_line="export HOMEBREW_BUNDLE_CASK_SKIP=\"$skip_line\""

if [ -f "$localrc" ] && grep -q "HOMEBREW_BUNDLE_CASK_SKIP" "$localrc"; then
  # Update existing line
  sed -i '' "s|^export HOMEBREW_BUNDLE_CASK_SKIP=.*|$export_line|" "$localrc"
  log_success "Updated HOMEBREW_BUNDLE_CASK_SKIP in ~/.localrc"
else
  # Append
  echo "" >> "$localrc"
  echo "# Casks to skip in brew bundle (installed outside Homebrew)" >> "$localrc"
  echo "$export_line" >> "$localrc"
  log_success "Added HOMEBREW_BUNDLE_CASK_SKIP to ~/.localrc"
fi

# Export for current session
export HOMEBREW_BUNDLE_CASK_SKIP="$skip_line"
}

_brew_skip_detect_main
